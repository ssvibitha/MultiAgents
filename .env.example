# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon recommended for cloud hosting)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-your-branch.region.aws.neon.tech/neondb?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Public URL of your Next.js app (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# A long, random secret string used to sign session tokens
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-string-here

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add your app URL to Authorized redirect URIs as: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── Gemini API (optional) ─────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Your Azure OpenAI resource endpoint
# Format: https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# API key from your Azure OpenAI resource
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# API version to use (default: 2025-01-01-preview)
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Deployment names for your Azure OpenAI models
# These match the names you gave when deploying the models in Azure AI Studio
AZURE_DEPLOYMENT_GPT5=gpt-5
AZURE_DEPLOYMENT_GPT5_MINI=gpt-5-mini

# ── Python Backend ────────────────────────────────────────────────────────────
# URL of the deployed FastAPI backend (used by the Next.js API route to reach the agent system)
# Use http://localhost:8000 for local development
PYTHON_BACKEND_URL=https://your-backend.onrender.com
